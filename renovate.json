{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "timezone": "America/New_York",
  "schedule": ["* 22-23,0-5 * * *"],
  "labels": ["dependencies"],

  "nix": {
    "enabled": true
  },

  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },

  "helmfile": {
    "managerFilePatterns": ["/k8s/helmfile\\.yaml$/"]
  },

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^k8s/charts/.*/templates/deployment\\.yaml$/"],
      "matchStrings": [
        "image:\\s+(?<depName>\\S+?):(?<currentValue>[^\\s@]+)@(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],

  "packageRules": [
    {
      "description": "Skip tranquil-pds (atcr.io needs separate creds)",
      "enabled": false,
      "matchPackageNames": ["/tranquil/"]
    },
    {
      "description": "Auto-merge routine updates after CI passes",
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest"],
      "automerge": true
    },
    {
      "description": "Major bumps stay manual",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ],

  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
