{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "timezone": "America/New_York",
  "schedule": ["every weekend"],
  "labels": ["dependencies"],

  "helmfile": {
    "managerFilePatterns": ["/k8s/helmfile\\.yaml$/"]
  },

  "regexManagers": [
    {
      "fileMatch": ["^k8s/charts/.*/templates/deployment\\.yaml$"],
      "matchStrings": [
        "image:\\s+(?<depName>\\S+?):(?<currentValue>[^\\s@]+)@(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],

  "packageRules": [
    {
      "description": "Skip tranquil-pds (atcr.io needs separate creds)",
      "enabled": false,
      "matchPackageNames": ["/tranquil/"]
    },
    {
      "description": "Auto-merge patch + digest updates after CI passes",
      "matchUpdateTypes": ["patch", "digest", "pin", "pinDigest"],
      "automerge": true
    },
    {
      "description": "Group helm chart minor bumps into one PR per week",
      "matchManagers": ["helmfile"],
      "matchUpdateTypes": ["minor"],
      "groupName": "helm chart minor updates"
    },
    {
      "description": "Major bumps stay manual",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ],

  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
